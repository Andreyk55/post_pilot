# ────────────────────────────────────────────────────────────────────────────
# PostPilot — local/dev environment template.
#
# Copy this to dev/local.env and fill in the secrets:
#   cp dev/local.env.example dev/local.env
#
# dev/local.env is .gitignored — safe to put real local credentials.
# ────────────────────────────────────────────────────────────────────────────

# Path to this env file (used by docker-compose env_file interpolation,
# resolved relative to the compose file at dev/docker-compose*.yml).
ENV_FILE=./local.env

# Pin the compose project name so container names don't depend on the
# folder name. Scripts tailing logs reference these by name.
COMPOSE_PROJECT_NAME=postpilot

# ── API runtime ────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
APP_RUN_MODE=local
API_PORT=5122
ASPNETCORE_URLS=http://0.0.0.0:5122

# ── Local Postgres (docker-compose service "postgres") ─────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postpilot
POSTGRES_PORT=5432
# Use Host=postgres from inside containers, Host=localhost from your shell.
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=postpilot;Username=postgres;Password=postgres

# ── pgAdmin ────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@postpilot.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# ── Meta / Facebook (use your own dev app credentials) ─────────────────────
META_APP_ID=REPLACE_ME
META_APP_SECRET=REPLACE_ME

# ── Gemini AI ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemma-3-27b-it
GEMINI_VISION_MODEL=REPLACE_ME

# ── App URLs (start.ps1 rewrites App__PublicUrl with the live ngrok URL) ───
App__PublicUrl=https://REPLACE_ME.ngrok-free.dev
Meta__RedirectUri=http://localhost:5173/oauth/meta/callback

# ── Private access (temporary single-password gate) ────────────────────────
# Off by default in dev. Flip to true to exercise the gate locally — then
# also set a PasswordHash (use scripts/gen-private-access-hash.ps1).
PrivateAccess__Enabled=false
# PrivateAccess__PasswordHash=
# PrivateAccess__CookieName=postpilot_private_access
# PrivateAccess__SessionDays=7

# ── Local MinIO ────────────────────────────────────────────────────────────
MINIO_ROOT_USER=postpilot
MINIO_ROOT_PASSWORD=postpilot-password
MEDIA_STORAGE_BUCKET=postpilot-media

MediaStorage__Provider=s3-compatible
MediaStorage__Bucket=postpilot-media
MediaStorage__InternalEndpoint=http://minio:9000
MediaStorage__PublicUploadEndpoint=http://localhost:9000
MediaStorage__AccessKey=postpilot
MediaStorage__SecretKey=postpilot-password
MediaStorage__UseSSL=false
MediaStorage__PresignedUploadExpirationMinutes=15
