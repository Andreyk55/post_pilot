# ────────────────────────────────────────────────────────────────────────────
# PostPilot — production env, LOCAL Postgres mode.
#
# Use this when you want the app to run against the in-compose
# postpilot-postgres container (no Supabase).
#
# Setup:
#   cp prod/server.local.env.example /opt/postpilot/server.env
#   nano /opt/postpilot/server.env            # replace every CHANGE_ME
#   chmod 600 /opt/postpilot/server.env
#
# Start the stack WITH the localdb profile so the postgres container runs:
#   docker compose -f prod/docker-compose.yml --profile localdb up -d
#
# NEVER commit the real /opt/postpilot/server.env.
# ────────────────────────────────────────────────────────────────────────────

# ── ASP.NET Core runtime ───────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5122

# ── App run mode ───────────────────────────────────────────────────────────
App__RunMode=Server
APP_RUN_MODE=Server
App__EnableHttpsRedirect=false

# ── Public URLs ────────────────────────────────────────────────────────────
Frontend__BaseUrl=https://post-auto-pilot.vercel.app
Backend__BaseUrl=https://post-pilot.cloud-ip.cc
App__PublicUrl=https://post-pilot.cloud-ip.cc

# ── CORS ───────────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=https://post-auto-pilot.vercel.app

# ── Private access gate ────────────────────────────────────────────────────
# PasswordHash is a BCrypt hash — generate via scripts/gen-private-access-hash.ps1.
PrivateAccess__Enabled=true
PrivateAccess__PasswordHash=CHANGE_ME_BCRYPT_HASH
PrivateAccess__CookieName=postpilot_private_access
PrivateAccess__SessionDays=7
PrivateAccess__CookieSigningKey=CHANGE_ME_RANDOM_32_CHARS

# ── Database: local Docker Postgres (postpilot-postgres compose service) ───
# These three POSTGRES_* vars are consumed by the postgres image to init the
# database; the ConnectionStrings__ line is what the .NET app uses. Keep all
# four passwords identical.
POSTGRES_DB=postpilot
POSTGRES_USER=postpilot
POSTGRES_PASSWORD=CHANGE_ME
ConnectionStrings__DefaultConnection=Host=postpilot-postgres;Port=5432;Database=postpilot;Username=postpilot;Password=CHANGE_ME

# ── Meta / Facebook ────────────────────────────────────────────────────────
Meta__AppId=CHANGE_ME
Meta__AppSecret=CHANGE_ME
Meta__RedirectUri=https://post-auto-pilot.vercel.app/oauth/meta/callback
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME

# ── Gemini AI ──────────────────────────────────────────────────────────────
Gemini__ApiKey=CHANGE_ME
Gemini__Model=gemini-2.0-flash
Gemini__VisionModel=gemini-2.0-flash
GEMINI_API_KEY=CHANGE_ME

# ── Media storage (MinIO, in-compose) ──────────────────────────────────────
MINIO_ROOT_USER=postpilot
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG
MEDIA_STORAGE_BUCKET=postpilot-media

MediaStorage__Provider=s3-compatible
MediaStorage__Bucket=postpilot-media
MediaStorage__InternalEndpoint=http://postpilot-minio:9000
MediaStorage__PublicUploadEndpoint=https://media.post-pilot.cloud-ip.cc
MediaStorage__AccessKey=postpilot
MediaStorage__SecretKey=CHANGE_ME_STRONG
MediaStorage__UseSSL=true
MediaStorage__PresignedUploadExpirationMinutes=15
