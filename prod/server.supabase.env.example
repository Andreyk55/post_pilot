# ────────────────────────────────────────────────────────────────────────────
# PostPilot — production env, SUPABASE Postgres + SUPABASE Storage mode.
#
# This is the default production deployment. Run against managed Supabase
# PostgreSQL and Supabase Storage; no in-compose postgres or MinIO container.
#
# Setup:
#   cp prod/server.supabase.env.example /opt/postpilot/server.env
#   nano /opt/postpilot/server.env            # replace every CHANGE_ME
#   chmod 600 /opt/postpilot/server.env
#
# Start the stack WITHOUT the localdb profile so postgres is skipped:
#   docker compose -f prod/docker-compose.yml up -d
#
# NEVER commit the real /opt/postpilot/server.env.
# NEVER expose MediaStorage__Supabase__ServiceRoleKey to the frontend or any
# Vercel build — it bypasses Supabase RLS and grants full project access.
# ────────────────────────────────────────────────────────────────────────────

# ── ASP.NET Core runtime ───────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5122

# ── App run mode ───────────────────────────────────────────────────────────
App__RunMode=Server
APP_RUN_MODE=Server
App__EnableHttpsRedirect=false

# ── Public URLs ────────────────────────────────────────────────────────────
Frontend__BaseUrl=https://post-auto-pilot.vercel.app
Backend__BaseUrl=https://post-pilot.cloud-ip.cc
App__PublicUrl=https://post-pilot.cloud-ip.cc

# ── CORS ───────────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=https://post-auto-pilot.vercel.app

# ── Private access gate ────────────────────────────────────────────────────
# PasswordHash is a BCrypt hash — generate via scripts/gen-private-access-hash.ps1.
PrivateAccess__Enabled=true
PrivateAccess__PasswordHash=CHANGE_ME_BCRYPT_HASH
PrivateAccess__CookieName=postpilot_private_access
PrivateAccess__SessionDays=7
PrivateAccess__CookieSigningKey=CHANGE_ME_RANDOM_32_CHARS

# ── Database: Supabase PostgreSQL ──────────────────────────────────────────
# Get the URI from Supabase: Project Settings → Database → Connection string.
# Format there: postgresql://postgres:[YOUR-PASSWORD]@db.<ref>.supabase.co:5432/postgres
# Converted to Npgsql key=value form below. SSL Mode=Require is mandatory
# (Supabase rejects plain TCP).
ConnectionStrings__DefaultConnection=Host=db.abc.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=CHANGE_ME;SSL Mode=Require;Trust Server Certificate=true;Pooling=true;Maximum Pool Size=10

# ── Meta / Facebook ────────────────────────────────────────────────────────
Meta__AppId=CHANGE_ME
Meta__AppSecret=CHANGE_ME
Meta__RedirectUri=https://post-auto-pilot.vercel.app/oauth/meta/callback
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME

# ── Gemini AI ──────────────────────────────────────────────────────────────
Gemini__ApiKey=CHANGE_ME
Gemini__Model=gemini-2.0-flash
Gemini__VisionModel=gemini-2.0-flash
GEMINI_API_KEY=CHANGE_ME

# ── Media storage (Supabase Storage) ───────────────────────────────────────
# The bucket must already exist in Supabase and MUST be PRIVATE — uploads and
# downloads go through short-lived signed URLs that the backend mints with the
# service role key.
#
# WARNING: ServiceRoleKey is a project-wide JWT that bypasses RLS. Treat it
# like a database password:
#   - set it here on the VPS only (backend + worker share this env file)
#   - NEVER add it to Vercel / any frontend build / public repo
#   - rotate it from the Supabase dashboard if it is ever leaked
MediaStorage__Provider=Supabase
MediaStorage__Supabase__Url=https://YOUR_PROJECT.supabase.co
MediaStorage__Supabase__ServiceRoleKey=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY
MediaStorage__Supabase__Bucket=postpilot-media
MediaStorage__Supabase__SignedUrlExpirySeconds=3600
MediaStorage__Supabase__MaxUploadBytes=104857600
