# ────────────────────────────────────────────────────────────────────────────
# PostPilot — production environment template.
#
# Copy this file to /opt/postpilot/server.env on the VPS and fill in every
# CHANGE_ME placeholder. NEVER commit the real /opt/postpilot/server.env.
#
# Used by prod/docker-compose.yml — same file is mounted into all three
# containers (postpilot-postgres, postpilot-api, postpilot-worker).
# ────────────────────────────────────────────────────────────────────────────

# ── ASP.NET Core runtime ───────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5122

# ── App run mode (canonical + legacy flat) ─────────────────────────────────
# RunMode=Server tells the .NET app it is the hosted production deployment.
App__RunMode=Server
APP_RUN_MODE=Server

# Behind nginx (TLS-terminating). Disable in-app HTTPS redirect so requests
# arriving over the loopback (already proxied) don't bounce.
App__EnableHttpsRedirect=false

# ── Public URLs ────────────────────────────────────────────────────────────
Frontend__BaseUrl=https://post-auto-pilot.vercel.app
Backend__BaseUrl=https://post-pilot.cloud-ip.cc
# Public URL Meta uses to fetch media during publishing. Must match the
# HTTPS hostname terminated by the host nginx.
App__PublicUrl=https://post-pilot.cloud-ip.cc

# ── CORS (allowlist — production must NOT allow any origin) ────────────────
# Indexed array binding for IConfiguration.GetSection("Cors:AllowedOrigins").
Cors__AllowedOrigins__0=https://post-auto-pilot.vercel.app

# ── Postgres (consumed by the postgres image AND the .NET app) ─────────────
POSTGRES_DB=postpilot
POSTGRES_USER=postpilot
POSTGRES_PASSWORD=CHANGE_ME

# Host=postpilot-postgres because containers resolve the DB by compose
# service name on the bridge network. Keep this password in sync with
# POSTGRES_PASSWORD above.
ConnectionStrings__DefaultConnection=Host=postpilot-postgres;Port=5432;Database=postpilot;Username=postpilot;Password=CHANGE_ME

# ── Meta / Facebook ────────────────────────────────────────────────────────
Meta__AppId=CHANGE_ME
Meta__AppSecret=CHANGE_ME
Meta__RedirectUri=https://post-auto-pilot.vercel.app/oauth/meta/callback
# Legacy flat names (kept for EnvVarMapper backward compat — same values)
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME

# ── Gemini AI ──────────────────────────────────────────────────────────────
Gemini__ApiKey=CHANGE_ME
Gemini__Model=gemini-2.0-flash
Gemini__VisionModel=gemini-2.0-flash
# Legacy flat name
GEMINI_API_KEY=CHANGE_ME

# ── Media storage (REQUIRED in Server mode) ────────────────────────────────
# Server mode hands presigned upload URLs to the browser, so the bytes must
# land in object storage that survives container replacement. The app
# refuses to start with App__RunMode=Server + MediaStorage__Provider=local-disk
# because the legacy PUT /api/media/upload/{file} endpoint is gated to Local
# mode and returns 404 — image uploads would silently break.
#
# This deployment uses self-hosted MinIO (prod/docker-compose.yml), exposed
# publicly via nginx at https://media.post-pilot.cloud-ip.cc (prod/nginx/postpilot-media.conf).
# To switch to managed S3-compatible storage later (R2, Spaces, B2, etc.),
# point the four MediaStorage__* host/credential vars at the new endpoint —
# no code change needed.

# MinIO root credentials. Consumed by the postpilot-minio container.
# Rotate these to a strong random value (32+ chars). Recommended once the
# bucket exists: create a service account scoped to postpilot-media via
#   `docker exec -it postpilot-minio-init mc admin user svcacct add ...`
# and use its access/secret pair for MediaStorage__AccessKey/SecretKey,
# leaving root credentials for break-glass only.
MINIO_ROOT_USER=postpilot
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG
# Consumed by postpilot-minio-init to create the bucket idempotently.
MEDIA_STORAGE_BUCKET=postpilot-media

# How the .NET app talks to storage.
# InternalEndpoint = container-to-container on the compose network (HTTP, no TLS).
# PublicUploadEndpoint = what the browser hits — must be HTTPS and must match
# MINIO_SERVER_URL in docker-compose.yml so signature v4 verification passes.
MediaStorage__Provider=s3-compatible
MediaStorage__Bucket=postpilot-media
MediaStorage__InternalEndpoint=http://postpilot-minio:9000
MediaStorage__PublicUploadEndpoint=https://media.post-pilot.cloud-ip.cc
MediaStorage__AccessKey=postpilot
MediaStorage__SecretKey=CHANGE_ME_STRONG
MediaStorage__UseSSL=true
MediaStorage__PresignedUploadExpirationMinutes=15
