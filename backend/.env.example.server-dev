# Post Pilot — Server Mode (dev server)
# Frontend uploads directly to a storage provider via pre-signed PUT URLs.
# Meta fetches media via pre-signed GET URLs.
# NOTE: ServerMediaStorageProvider is a stub. Implement IMediaStorageProvider
#       and register it in Startup.cs before using server mode.
#
# Env var naming: prefer App__RunMode style (canonical, section-separated).
# Legacy flat names (APP_RUN_MODE, etc.) still work but are deprecated.

# ── App ──────────────────────────────────────────────────────────────
App__RunMode=server
ASPNETCORE_ENVIRONMENT=Development
# DEPRECATED (compat only): APP_RUN_MODE=server

# ── Meta OAuth (Facebook/Instagram) ──────────────────────────────────
Meta__AppId=your_meta_app_id
Meta__AppSecret=your_meta_app_secret
# DEPRECATED (compat only): META_APP_ID / META_APP_SECRET

# ── AI Services ──────────────────────────────────────────────────────
Gemini__ApiKey=your_gemini_api_key
Gemini__Model=gemini-2.0-flash
# DEPRECATED (compat only): GEMINI_API_KEY / GEMINI_MODEL

# Optional: Separate vision model for image analysis (defaults to Gemini__Model)
# Gemini__VisionModel=gemini-2.0-flash

# Optional: Public URL override for media access
# App__PublicUrl=https://dev.yourapp.com
