# Post Pilot — Local Mode (developer's machine)
# Backend receives uploads and stores files to disk under uploads/

APP_RUN_MODE=local

# Database
DB_CONNECTION_STRING=Host=localhost;Port=5432;Database=postpilot;Username=postgres;Password=yourpassword

# Meta OAuth (Facebook/Instagram)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# AI Services
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Optional: Public URL for ngrok/tunneling (so Meta can fetch local media)
# PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# Local media settings (all optional, defaults shown)
# MEDIA_LOCAL_ROOT=uploads
# MEDIA_UPLOAD_URL_EXPIRATION_MINUTES=60
