{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Features": {
    "EnableFacebookThumbnail": false
  },
  "Ai": {
    "LanguageDetectorProvider": "gemini",
    "CaptionGeneratorProvider": "gemini",
    "RateLimiter": {
      "MaxCallsPerDay": 20,
      "WindowHours": 24
    }
  },
  "AllowedHosts": "*"
}
