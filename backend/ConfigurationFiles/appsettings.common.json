{
  "App": {
    "PublicUrl": ""
  },
  "Gemini": {
    "Model": "gemini-2.0-flash",
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta",
    "TimeoutSeconds": 30
  },
  "Publishing": {
    "WorkerPollIntervalSeconds": 30,
    "StuckPostThresholdMinutes": 5,
    "StuckPostRetryDelaySeconds": 10,
    "MediaDownloadUrlExpirationMinutes": 60,
    "VideoDownloadUrlExpirationMinutes": 120,
    "ImagePollMaxAttempts": 30,
    "ImagePollIntervalSeconds": 2,
    "OAuthStateExpirationMinutes": 10
  },
  "Media": {
    "UploadUrlExpirationMinutes": 60,
    "MaxImageFileSizeBytes": 20971520,
    "MaxVideoFileSizeBytes": 209715200,
    "LocalServerBaseUrl": "http://localhost:5122"
  },
  "MediaStorage": {
    "Provider": "local-disk",
    "PresignedUploadExpirationMinutes": 15
  },
  "Features": {
    "EnableEngagementFetch": false,
    "EnableFacebookThumbnail": false,
    "PlatformSelection": {
      "MaxPlatformsPerPost": 1
    }
  },
  "PrivateAccess": {
    "Enabled": false,
    "PasswordHash": "",
    "CookieName": "postpilot_private_access",
    "SessionDays": 7
  },
  "Auth": {
    "FrontendUrl": "",
    "AllowedOrigins": [],
    "CookieDomain": "",
    "RequireHttpsCookies": true,
    "CookieName": "postpilot_session"
  },
  "GoogleAuth": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Ai": {
    "RateLimiter": {
      "MaxCallsPerDay": 20,
      "WindowHours": 24
    },
    "Providers": {
      "LanguageDetectorProvider": "gemini",
      "CaptionGeneratorProvider": "gemini"
    },
    "CacheDurations": {
      "CaptionAssistMinutes": 60,
      "LanguageDetectionMinutes": 1440,
      "GoogleAiClientMinutes": 60,
      "PostTimeSuggestionMinutes": 10,
      "AssetResolverDownloadUrlExpirationMinutes": 15
    }
  }
}
