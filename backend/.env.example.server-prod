# Post Pilot — Server Mode (production)
# Frontend uploads directly to a storage provider via pre-signed PUT URLs.
# Meta fetches media via pre-signed GET URLs.
# NOTE: ServerMediaStorageProvider is a stub. Implement IMediaStorageProvider
#       and register it in Startup.cs before using server mode.

APP_RUN_MODE=server
ASPNETCORE_ENVIRONMENT=Production

# Meta OAuth (Facebook/Instagram)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# AI Services
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Optional: Public URL override for media access
# PUBLIC_URL=https://yourapp.com

# Optional: Separate vision model for image analysis (defaults to GEMINI_MODEL)
# GEMINI_VISION_MODEL=gemini-2.0-flash
