# Post Pilot — Server Mode (production)
# Frontend uploads directly to a storage provider via pre-signed PUT URLs.
# Meta fetches media via pre-signed GET URLs.
# NOTE: ServerMediaStorageProvider is a stub. Implement IMediaStorageProvider
#       and register it in Startup.cs before using server mode.

APP_RUN_MODE=server
ASPNETCORE_ENVIRONMENT=Production

# Database
DB_CONNECTION_STRING=Host=prod-db.example.com;Port=5432;Database=postpilot;Username=app;Password=prodpassword;SslMode=Require

# Meta OAuth (Facebook/Instagram)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://yourapp.com/oauth/meta/callback

# AI Services
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Optional: URL expiration settings (defaults shown)
# MEDIA_UPLOAD_URL_EXPIRATION_MINUTES=60
# MEDIA_DOWNLOAD_IMAGE_EXPIRATION_MINUTES=60
# MEDIA_DOWNLOAD_VIDEO_EXPIRATION_MINUTES=360
