{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Features": {
    "EnableEngagementFetch": false,
    "EnableFacebookThumbnail": false,
    "PlatformSelection": {
      "MaxPlatformsPerPost": 1
    }
  },
  "Ai": {
    "LanguageDetectorProvider": "gemini",
    "CaptionGeneratorProvider": "gemini",
    "RateLimiter": {
      "MaxCallsPerDay": 20,
      "WindowHours": 24
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
