{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Features": {
    "EnableEngagementFetch": false,
    "EnableFacebookThumbnail": false,
    "PlatformSelection": {
      "MaxPlatformsPerPost": 1
    }
  },
  "Ai": {
    "LanguageDetectorProvider": "gemini",
    "CaptionGeneratorProvider": "gemini",
    "RateLimiter": {
      "MaxCallsPerDay": 20,
      "WindowHours": 24
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "PostPilot": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.EntityFrameworkCore.Query": "Warning",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    },
    "EnableEfSql": false
  },
  "AllowedHosts": "*"
}
