{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=postpilot;Username=postgres;Password=postgres"
  },
  "Meta": {
    "RedirectUri": "http://localhost:5173/oauth/meta/callback"
  },
  "Features": {
    "EnableFacebookThumbnail": false
  },
  "Ai": {
    "LanguageDetectorProvider": "gemini",
    "CaptionGeneratorProvider": "gemini",
    "RateLimiter": {
      "MaxCallsPerDay": 200,
      "WindowHours": 24
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
